							<LEFT>102</LEFT>
							<RIGHT>302</RIGHT>
							<TOP>30</TOP>
							<BOTTOM>50</BOTTOM>
						</POSITION>
						<STRING edge="5" justify="LEFT" vjustify="CENTER"></STRING>
						<SOUND state="mousein" trigger="MOVER_COMBO">menu.lwf</SOUND>
					</WINDOW>
					<WINDOW type="static" name="STATIC_SERVER_MESSAGE">
						<POSITION>
							<LEFT>0</LEFT>
							<RIGHT>100</RIGHT>
							<TOP>60</TOP>
							<BOTTOM>80</BOTTOM>
						</POSITION>
						<STRING justify="LEFT" vjustify="CENTER" type="id">HG_MESSAGE</STRING>
					</WINDOW>
					<WINDOW type="edit" name="SERVER_MESSAGE" MAXCHAR="128">
						<APPEARANCE type="image" state="default" map_state="0" height="20">btn1d.tga</APPEARANCE>
						<APPEARANCE type="image" state="mouseover" map_state="1" height="20">btn1d.tga</APPEARANCE>
						<APPEARANCE type="image" state="selected" map_state="2" height="20">btn1d.tga</APPEARANCE>
						<APPEARANCE type="image" state="disabled" map_state="3" height="20">btn1d.tga</APPEARANCE>
						<POSITION>
							<LEFT>102</LEFT>
							<RIGHT>302</RIGHT>
							<TOP>60</TOP>
							<BOTTOM>80</BOTTOM>
						</POSITION>
						<STRING edge="5" justify="LEFT" vjustify="CENTER" type="id">HG_WELCOME</STRING>
						<SOUND state="mousein" trigger="MOVER_COMBO">menu.lwf</SOUND>
					</WINDOW>
					<WINDOW type="static" name="STATIC_SERVERTYPE">
						<POSITION>
							<LEFT>350</LEFT>
							<RIGHT>500</RIGHT>
							<TOP>0</TOP>
							<BOTTOM>24</BOTTOM>
						</POSITION>
						<STRING justify="LEFT" vjustify="CENTER" type="id">HG_SVRTYPE</STRING>
					</WINDOW>
					<WINDOW type="spinlist" name="SERVERTYPE">
