<SCREEN>
	<NAME>STARTUP</NAME>
	<MUSICVAR>1</MUSICVAR>
	<WINDOW type="window" name="MAIN">
		<APPEARANCE type="image" state="default">Main.tga</APPEARANCE>
		<POSITION>
			<LEFT>0</LEFT>
			<TOP>0</TOP>
			<RIGHT>800</RIGHT>
			<BOTTOM>600</BOTTOM>
		</POSITION>
		<TEXT_RSRC>menutxt.BIN</TEXT_RSRC>
		<CURSOR>
			<FILE>newarow1.tga</FILE>
			<FLAGS>STANDARD_TRANSPARENT</FLAGS>
		</CURSOR>
		<WINDOW type="window" name="BUTTONS">
			<FONT>
				<NAME>%DEF_FONTNAME_XL%</NAME>
				<DEFAULT_FG>%DEF_TEXT_FG%</DEFAULT_FG>
				<MOUSEOVER_FG>%DEF_TEXT_MOUSEOVER_FG%</MOUSEOVER_FG>
				<SELECTED_FG>%DEF_TEXT_SELECTED_FG%</SELECTED_FG>
				<DISABLED_FG>%DEF_TEXT_DISABLED_FG%</DISABLED_FG>
			</FONT>
			<POSITION>
				<LEFT>60</LEFT>
				<TOP>150</TOP>
			</POSITION>
			<WINDOW type="button" name="SINGLE_PLAYER">
				<ACTION type="screen" file="sp.mnu">SINGLE_PLAYER</ACTION>
				<APPEARANCE state="default"></APPEARANCE>
				<APPEARANCE state="mouseover"></APPEARANCE>
				<APPEARANCE state="selected"></APPEARANCE>
				<APPEARANCE state="disabled"></APPEARANCE>
				<SOUND state="mousein" trigger="MOUSE_OVER">menu.lwf</SOUND>
				<SOUND state="selected" trigger="CLICK_SELECT">menu.lwf</SOUND>
				<POSITION>
					<TOP>50</TOP>
					<LEFT>0</LEFT>
					<RIGHT>0</RIGHT>
				</POSITION>
				<STRING type="id" justify="LEFT">MM_Singleplayer</STRING>
			</WINDOW>
			<WINDOW type="button" name="NW_MULTI_PLAYER">
				<APPEARANCE state="default"></APPEARANCE>
				<APPEARANCE state="mouseover"></APPEARANCE>
				<APPEARANCE state="selected"></APPEARANCE>
				<APPEARANCE state="disabled"></APPEARANCE>
				<SOUND state="mousein" trigger="MOUSE_OVER">menu.lwf</SOUND>
				<SOUND state="selected" trigger="CLICK_SELECT">menu.lwf</SOUND>
				<POSITION>
					<TOP>100</TOP>
					<LEFT>0</LEFT>
					<RIGHT>0</RIGHT>
				</POSITION>
				<STRING type="id" justify="LEFT">MM_NWMultiplayer</STRING>
			</WINDOW>
			<WINDOW type="button" name="LAN_MULTI_PLAYER">
				<ACTION type="screen" file="mp.mnu">LAN_MULTI_PLAYER</ACTION>
				<APPEARANCE state="default"></APPEARANCE>
				<APPEARANCE state="mouseover"></APPEARANCE>
				<APPEARANCE state="selected"></APPEARANCE>
				<APPEARANCE state="disabled"></APPEARANCE>
				<SOUND state="mousein" trigger="MOUSE_OVER">menu.lwf</SOUND>
				<SOUND state="selected" trigger="CLICK_SELECT">menu.lwf</SOUND>
				<POSITION>
					<TOP>150</TOP>
					<LEFT>0</LEFT>
					<RIGHT>0</RIGHT>
				</POSITION>
				<STRING justify="LEFT">LAN</STRING>
			</WINDOW>
			<WINDOW type="button" name="PLAYER_INFO">
				<ACTION type="screen" file="player.mnu">PLAYER_INFO</ACTION>
				<APPEARANCE state="default"></APPEARANCE>
				<APPEARANCE state="mouseover"></APPEARANCE>
				<APPEARANCE state="selected"></APPEARANCE>
				<APPEARANCE state="disabled"></APPEARANCE>
				<SOUND state="mousein" trigger="MOUSE_OVER">menu.lwf</SOUND>
				<SOUND state="selected" trigger="CLICK_SELECT">menu.lwf</SOUND>
				<POSITION>
					<TOP>200</TOP>
					<LEFT>0</LEFT>
					<RIGHT>0</RIGHT>
				</POSITION>
				<STRING type="id" justify="LEFT">MM_ChangePilot</STRING>
			</WINDOW>
			<WINDOW type="button" name="OPTIONS">
				<ACTION type="screen" file="options.mnu">OPTIONS</ACTION>
				<APPEARANCE state="default"></APPEARANCE>
				<APPEARANCE state="mouseover"></APPEARANCE>
				<APPEARANCE state="selected"></APPEARANCE>
				<APPEARANCE state="disabled"></APPEARANCE>
				<SOUND state="mousein" trigger="MOUSE_OVER">menu.lwf</SOUND>
				<SOUND state="selected" trigger="CLICK_SELECT">menu.lwf</SOUND>
				<POSITION>
					<TOP>250</TOP>
					<LEFT>0</LEFT>
					<RIGHT>0</RIGHT>
				</POSITION>
				<STRING type="id" justify="LEFT">MM_Options</STRING>
			</WINDOW>
			<WINDOW type="button" name="DATABASE" DISABLE HIDDEN>
				<ACTION type="screen" file="item_db.mnu">ITEM_DATABASE</ACTION>
				<APPEARANCE state="default"></APPEARANCE>
				<APPEARANCE state="mouseover"></APPEARANCE>
				<APPEARANCE state="selected"></APPEARANCE>
				<APPEARANCE state="disabled"></APPEARANCE>
				<SOUND state="mousein" trigger="MOUSE_OVER">menu.lwf</SOUND>
				<SOUND state="selected" trigger="CLICK_SELECT">menu.lwf</SOUND>
				<POSITION>
					<TOP>300</TOP>
					<LEFT>0</LEFT>
					<RIGHT>0</RIGHT>
				</POSITION>
				<STRING type="id" justify="LEFT">MM_Database</STRING>
			</WINDOW>
<!--
			<WINDOW type="button" name="UPDATE">
				<APPEARANCE state="default"></APPEARANCE>
				<APPEARANCE state="mouseover"></APPEARANCE>
				<APPEARANCE state="selected"></APPEARANCE>
				<APPEARANCE state="disabled"></APPEARANCE>
				<SOUND state="mousein" trigger="MOUSE_OVER">menu.lwf</SOUND>
				<SOUND state="selected" trigger="CLICK_SELECT">menu.lwf</SOUND>
				<POSITION>
					<TOP>350</TOP>
					<LEFT>0</LEFT>
					<RIGHT>0</RIGHT>
				</POSITION>
				<STRING type="id" justify="LEFT">MM_UPDATE</STRING>
			</WINDOW>
-->
			<WINDOW type="button" name="EXIT">
				<APPEARANCE state="default"></APPEARANCE>
				<APPEARANCE state="mouseover"></APPEARANCE>
				<APPEARANCE state="selected"></APPEARANCE>
				<APPEARANCE state="disabled"></APPEARANCE>
				<SOUND state="mousein" trigger="MOUSE_OVER">menu.lwf</SOUND>
				<SOUND state="selected" trigger="CLICK_SELECT">menu.lwf</SOUND>
				<POSITION>
					<TOP>300</TOP>
					<LEFT>0</LEFT>
					<RIGHT>0</RIGHT>
				</POSITION>
				<STRING type="id" justify="LEFT">MM_Exit</STRING>
			</WINDOW>
			<WINDOW type="static" name="VERSION">
				<FONT>
					<NAME>%DEF_FONTNAME%</NAME>
					<DEFAULT_FG>%DEF_TEXT_SUBTLE_FG%</DEFAULT_FG>
					<DEFAULT_BG>000000</DEFAULT_BG>
					<DISABLED_FG>746038</DISABLED_FG>
					<DISABLED_BG>000000</DISABLED_BG>
					<SELECTED_FG>e2900a</SELECTED_FG>
					<SELECTED_BG>000000</SELECTED_BG>
					<MOUSEOVER_FG>FF0000</MOUSEOVER_FG>
					<MOUSEOVER_BG>000000</MOUSEOVER_BG>
				</FONT>
				<POSITION>
				    <LEFT>370</LEFT>
					<RIGHT>715</RIGHT>
					<TOP>433</TOP>
				</POSITION>
				<STRING justify="RIGHT"></STRING>
			</WINDOW>
			<WINDOW type="static" name="VERSION">
				<FONT>
					<NAME>%DEF_FONTNAME%</NAME>
					<DEFAULT_FG>%DEF_TEXT_SUBTLE_FG%</DEFAULT_FG>
					<DEFAULT_BG>000000</DEFAULT_BG>
					<DISABLED_FG>746038</DISABLED_FG>
					<DISABLED_BG>000000</DISABLED_BG>
					<SELECTED_FG>e2900a</SELECTED_FG>
					<SELECTED_BG>000000</SELECTED_BG>
					<MOUSEOVER_FG>FF0000</MOUSEOVER_FG>
					<MOUSEOVER_BG>000000</MOUSEOVER_BG>
				</FONT>
				<POSITION>
					<LEFT>0</LEFT>
					<RIGHT>785</RIGHT>
					<TOP>433</TOP>
				</POSITION>
				<STRING justify="LEFT">(c)2009 NovaLogic, Inc.</STRING>
			</WINDOW>
		</WINDOW>
	</WINDOW>
</SCREEN>

<SCREEN>
	<NAME>NW_LAN_HOST</NAME>
	<MUSICVAR>8</MUSICVAR>
	<WINDOW type="window" name="MAIN">
		<APPEARANCE type="image" state="default">letterbox.tga</APPEARANCE>
		<POSITION>
			<LEFT>0</LEFT>
			<TOP>0</TOP>
			<RIGHT>800</RIGHT>
			<BOTTOM>600</BOTTOM>
		</POSITION>
		<TEXT_RSRC>menutxt.BIN</TEXT_RSRC>
		<CURSOR>
			<FILE>newarow1.tga</FILE>
			<FLAGS>STANDARD_TRANSPARENT</FLAGS>
		</CURSOR>
		<FONT>
			<NAME>%DEF_FONTNAME%</NAME>
			<DEFAULT_FG>%DEF_TEXT_FG%</DEFAULT_FG>
			<MOUSEOVER_FG>%DEF_TEXT_MOUSEOVER_FG%</MOUSEOVER_FG>
			<SELECTED_FG>%DEF_TEXT_SELECTED_FG%</SELECTED_FG>
			<DISABLED_FG>%DEF_TEXT_DISABLED_FG%</DISABLED_FG>
		</FONT>

		<WINDOW type="window" name="ALIGNMENT_WRAPPER">
			<POSITION>
				<TOP>75</TOP>
				<LEFT>0</LEFT>
			</POSITION>
	<!-- bink panels begin-->
			<WINDOW type="window" name="LOGO_SPLASH_HDR">
				<APPEARANCE type="custom" state="default"></APPEARANCE>
				<POSITION>
					<TOP>-75</TOP>
					<BOTTOM>0</BOTTOM>
					<LEFT>0</LEFT>
					<RIGHT>801</RIGHT>
				</POSITION>
			</WINDOW>
			<WINDOW type="window" name="LOGO_SPLASH_FTR">
				<APPEARANCE type="custom" state="default"></APPEARANCE>
				<POSITION>
					<TOP>450</TOP>
					<BOTTOM>525</BOTTOM>
					<LEFT>0</LEFT>
					<RIGHT>801</RIGHT>
				</POSITION>
			</WINDOW>
	<!-- bink panels end-->

			<WINDOW type="window" name="WRAPPER">
				<POSITION>
					<LEFT>0</LEFT>
					<TOP>-75</TOP>
				</POSITION>
				<WINDOW type="window">
					<APPEARANCE type="outline" state="default">%TRIM_COLOR%</APPEARANCE>
					<POSITION>
						<TOP>79</TOP>
						<BOTTOM>79</BOTTOM>
						<LEFT>0</LEFT>
						<RIGHT>801</RIGHT>
					</POSITION>
				</WINDOW>
				<WINDOW type="window" name="HOST_TABS_WRAPPER">
					<FONT>
						<NAME>%DEF_FONTNAME_BODY%</NAME>
						<DEFAULT_FG>%DEF_TEXT_FG%</DEFAULT_FG>
						<MOUSEOVER_FG>%DEF_TEXT_MOUSEOVER_FG%</MOUSEOVER_FG>
						<SELECTED_FG>%DEF_TEXT_SELECTED_FG%</SELECTED_FG>
						<DISABLED_FG>%DEF_TEXT_DISABLED_FG%</DISABLED_FG>
					</FONT>
					<WINDOW type="radio" name="RADIO_TAB_HOST_GENERAL">
						<GROUP>10</GROUP>
						<ACTION type="window" state="SHOW">TAB_HOST_GENERAL</ACTION>
						<ACTION type="window" state="HIDE">TAB_HOST_GAME</ACTION>
						<ACTION type="window" state="HIDE">TAB_HOST_WEAPON</ACTION>
						<APPEARANCE type="image" state="default"   map_state="0" height="25">tab_mid.tga</APPEARANCE>
						<APPEARANCE type="image" state="mouseover" map_state="1" height="25">tab_mid.tga</APPEARANCE>
						<APPEARANCE type="image" state="selected"  map_state="2" height="25">tab_mid.tga</APPEARANCE>
						<APPEARANCE type="image" state="disabled"  map_state="3" height="25">tab_mid.tga</APPEARANCE>
						<POSITION>
							<LEFT>10</LEFT>
							<TOP>55</TOP>
							<BOTTOM>80</BOTTOM>
						</POSITION>
						<STRING type="ID" justify="CENTER" vjustify="CENTER">TAB_GENERAL</STRING>
						<SOUND state="mousein" trigger="MOUSE_OVER">menu.lwf</SOUND>
						<SOUND state="selected" trigger="CLICK_SELECT">menu.lwf</SOUND>
					</WINDOW>
					<WINDOW type="radio" name="RADIO_TAB_HOST_GAME">
						<GROUP>10</GROUP>
						<ACTION type="window" state="HIDE">TAB_HOST_GENERAL</ACTION>
						<ACTION type="window" state="SHOW">TAB_HOST_GAME</ACTION>
						<ACTION type="window" state="HIDE">TAB_HOST_WEAPON</ACTION>
						<APPEARANCE type="image" state="default"   map_state="0" height="25">tab_mid.tga</APPEARANCE>
						<APPEARANCE type="image" state="mouseover" map_state="1" height="25">tab_mid.tga</APPEARANCE>
						<APPEARANCE type="image" state="selected"  map_state="2" height="25">tab_mid.tga</APPEARANCE>
						<APPEARANCE type="image" state="disabled"  map_state="3" height="25">tab_mid.tga</APPEARANCE>
						<POSITION>
							<LEFT>210</LEFT>
							<TOP>55</TOP>
							<BOTTOM>80</BOTTOM>
						</POSITION>
						<STRING type="ID" justify="CENTER" vjustify="CENTER">TAB_GAME</STRING>
						<SOUND state="mousein" trigger="MOUSE_OVER">menu.lwf</SOUND>
						<SOUND state="selected" trigger="CLICK_SELECT">menu.lwf</SOUND>
					</WINDOW>
					<WINDOW type="radio" name="RADIO_TAB_HOST_WEAPON">
						<GROUP>10</GROUP>
						<ACTION type="window" state="HIDE">TAB_HOST_GENERAL</ACTION>
						<ACTION type="window" state="HIDE">TAB_HOST_GAME</ACTION>
						<ACTION type="window" state="SHOW">TAB_HOST_WEAPON</ACTION>
						<APPEARANCE type="image" state="default"   map_state="0" height="25">tab_mid.tga</APPEARANCE>
						<APPEARANCE type="image" state="mouseover" map_state="1" height="25">tab_mid.tga</APPEARANCE>
						<APPEARANCE type="image" state="selected"  map_state="2" height="25">tab_mid.tga</APPEARANCE>
						<APPEARANCE type="image" state="disabled"  map_state="3" height="25">tab_mid.tga</APPEARANCE>
						<POSITION>
							<LEFT>410</LEFT>
							<TOP>55</TOP>
							<BOTTOM>80</BOTTOM>
						</POSITION>
						<STRING type="ID" justify="CENTER" vjustify="CENTER">TAB_WEAPON</STRING>
						<SOUND state="mousein" trigger="MOUSE_OVER">menu.lwf</SOUND>
						<SOUND state="selected" trigger="CLICK_SELECT">menu.lwf</SOUND>
					</WINDOW>
				</WINDOW>
				<WINDOW type="window">

				<WINDOW type="window" name="TAB_HOST_GENERAL">
					<POSITION>
						<LEFT>40</LEFT>
						<TOP>110</TOP>
					</POSITION>
					<WINDOW type="static" name="STATIC_GAME_NAME">
						<POSITION>
							<LEFT>0</LEFT>
							<RIGHT>100</RIGHT>
							<TOP>0</TOP>
							<BOTTOM>20</BOTTOM>
						</POSITION>
						<STRING justify="LEFT" vjustify="CENTER" type="id">HG_GAMENAME</STRING>
					</WINDOW>
					<WINDOW type="edit" name="GAME_NAME" MAXCHAR="31">
						<APPEARANCE type="image" state="default" map_state="0" height="20">btn1d.tga</APPEARANCE>
						<APPEARANCE type="image" state="mouseover" map_state="1" height="20">btn1d.tga</APPEARANCE>
						<APPEARANCE type="image" state="selected" map_state="2" height="20">btn1d.tga</APPEARANCE>
						<APPEARANCE type="image" state="disabled" map_state="3" height="20">btn1d.tga</APPEARANCE>
						<POSITION>
							<LEFT>102</LEFT>
							<RIGHT>302</RIGHT>
							<TOP>0</TOP>
							<BOTTOM>20</BOTTOM>
						</POSITION>
						<STRING type="id" edge="5" justify="LEFT" vjustify="CENTER">HG_GAMENAME</STRING>
						<SOUND state="mousein" trigger="MOVER_COMBO">menu.lwf</SOUND>
					</WINDOW>
					<WINDOW type="static" name="STATIC_PASSWORD">
						<POSITION>
							<LEFT>0</LEFT>
							<RIGHT>100</RIGHT>
							<TOP>30</TOP>
							<BOTTOM>50</BOTTOM>
						</POSITION>
						<STRING justify="LEFT" vjustify="CENTER" type="id">HG_PASSWORD</STRING>
					</WINDOW>
					<WINDOW type="edit" name="SERVER_PASSWORD" MAXCHAR="16">
						<APPEARANCE type="image" state="default" map_state="0" height="20">btn1d.tga</APPEARANCE>
						<APPEARANCE type="image" state="mouseover" map_state="1" height="20">btn1d.tga</APPEARANCE>
						<APPEARANCE type="image" state="selected" map_state="2" height="20">btn1d.tga</APPEARANCE>
						<APPEARANCE type="image" state="disabled" map_state="3" height="20">btn1d.tga</APPEARANCE>
